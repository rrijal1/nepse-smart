# Database Configuration
DATABASE_URL=postgresql://nepse_user:nepse_password@postgres:5432/nepse_db

# For local development (without Docker), use:
# DATABASE_URL=postgresql://nepse_user:nepse_password@localhost:5432/nepse_db

# API Configuration
VITE_API_BASE_URL=http://localhost:8000

# PostgreSQL Database Settings (used by docker-compose)
POSTGRES_USER=nepse_user
POSTGRES_PASSWORD=nepse_password
POSTGRES_DB=nepse_db
